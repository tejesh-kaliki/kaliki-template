version: 0.1.0

environment:
  sdk: ">=3.5.0 <4.0.0"

dependencies:
  dio: ^5.4.0
  json_annotation: ^4.9.0
  retrofit: ^4.1.0

dev_dependencies:
  build_runner: ^2.4.0
  json_serializable: ^6.8.0
  retrofit_generator: ^9.1.0
  swagger_parser: ^1.18.0
