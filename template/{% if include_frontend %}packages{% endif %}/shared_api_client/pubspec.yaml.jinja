name: shared_api_client
description: Retrofit/Dio API client generated from the OpenAPI spec.
publish_to: "none"
version: 0.1.0

environment:
  sdk: ">=3.5.0 <4.0.0"

dependencies:
  dio: ^5.9.0
  freezed_annotation: ^3.1.0
  json_annotation: ^4.9.0
  retrofit: ^4.9.2

dev_dependencies:
  build_runner: ^2.10.3
  freezed: ^3.2.3
  json_serializable: ^6.11.2
  retrofit_generator: ^10.2.1
  # Fork of swagger_parser adding x-dart-type / x-dart-import support, so
  # OpenAPI `format: date` can map to LocalDate (see lib_custom/local_date.dart)
  # instead of DateTime, which otherwise breaks backend date validation.
  swagger_parser:
    git:
      url: https://github.com/tejesh-kaliki/swagger_parser
      path: swagger_parser
      ref: feat/x-dart-type
