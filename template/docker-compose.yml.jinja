services:
  postgres:
    image: postgres:17-alpine
    environment:
      POSTGRES_USER: ${POSTGRES_USER:-postgres}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-postgres}
      POSTGRES_DB: ${POSTGRES_DB:-{{ db_name }}}
    ports:
      - "${POSTGRES_PORT:-5432}:5432"
    volumes:
      - pgdata:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-postgres}"]
      interval: 5s
      timeout: 5s
      retries: 5
{%- if caching == 'redis' %}

  redis:
    image: redis:7-alpine
    ports:
      - "${REDIS_PORT:-6379}:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
{%- endif %}
{%- if eventing == 'kafka-redpanda' %}

  redpanda:
    image: redpandadata/redpanda:latest
    command:
      - redpanda start
      - --smp 1
      - --overprovisioned
      - --kafka-addr PLAINTEXT://0.0.0.0:9092
      - --advertise-kafka-addr PLAINTEXT://redpanda:9092
    ports:
      - "9092:9092"
    healthcheck:
      test: ["CMD-SHELL", "rpk cluster health | grep -q 'Healthy:.*true'"]
      interval: 5s
      timeout: 5s
      retries: 10
{%- endif %}
{%- if auth == 'jwt-full' and mailer %}

  # Mailpit captures all outgoing mail locally. Web UI on http://localhost:8025
  mailpit:
    image: axllent/mailpit:latest
    ports:
      - "${MAILPIT_SMTP_PORT:-1025}:1025"
      - "${MAILPIT_UI_PORT:-8025}:8025"
{%- endif %}

  backend:
    build:
      context: ./backend
    environment:
      DATABASE_URL: postgres://${POSTGRES_USER:-postgres}:${POSTGRES_PASSWORD:-postgres}@postgres:5432/${POSTGRES_DB:-{{ db_name }}}?sslmode=disable
      SERVER_PORT: "8080"
      APP_ENV: ${APP_ENV:-development}
{%- if auth != 'none' %}
      JWT_SECRET: ${JWT_SECRET:-dev-insecure-change-me}
{%- endif %}
{%- if auth == 'jwt-full' and mailer %}
      MAIL_PROVIDER: smtp
      SMTP_HOST: mailpit
      SMTP_PORT: "1025"
      MAIL_SENDER_ADDRESS: ${MAIL_SENDER_ADDRESS:-no-reply@{{ org_domain }}}
      MAIL_BASE_URL: ${MAIL_BASE_URL:-http://localhost:8080}
{%- endif %}
{%- if caching == 'redis' %}
      REDIS_URL: redis://redis:6379
{%- endif %}
{%- if eventing == 'kafka-redpanda' %}
      KAFKA_BROKERS: redpanda:9092
{%- endif %}
    ports:
      - "${BACKEND_PORT:-8080}:8080"
    depends_on:
      postgres:
        condition: service_healthy
{%- if caching == 'redis' %}
      redis:
        condition: service_healthy
{%- endif %}
{%- if eventing == 'kafka-redpanda' %}
      redpanda:
        condition: service_healthy
{%- endif %}
{%- if auth == 'jwt-full' and mailer %}
      mailpit:
        condition: service_started
{%- endif %}

volumes:
  pgdata:
