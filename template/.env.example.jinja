# Copy to .env and adjust. Consumed by docker-compose.
# APP_ENV=production makes the backend refuse to boot with the dev JWT secret.
APP_ENV=development
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB={{ db_name }}
POSTGRES_PORT=5432
BACKEND_PORT=8080
# CORS: in development (APP_ENV != production) the API reflects any Origin so the
# frontend works out of the box. In production set an explicit allowlist:
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
{%- if caching == 'redis' %}
REDIS_PORT=6379
{%- endif %}
{%- if auth == 'jwt-full' and mailer %}
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MAIL_SENDER_ADDRESS=no-reply@{{ org_domain }}
MAIL_BASE_URL=http://localhost:8080
{%- endif %}
