server:
  port: "8080"

database:
  # Overridden by DATABASE_URL in docker-compose.
  url: "postgres://postgres:postgres@localhost:5432/{{ db_name }}?sslmode=disable"

observability:
  service_name: "{{ project_slug }}-backend"
  # Leave empty for the no-op tracer. Set to an OTLP collector endpoint to export.
  endpoint: ""
{%- if auth != 'none' %}

token:
  # Overridden by JWT_SECRET in docker-compose. Change this in production.
  secret: "dev-insecure-change-me"
  expiry_hours: 24
{%- endif %}
{%- if auth == 'jwt-full' %}

mail:
  # provider: smtp | ses | (empty -> log transport; prints emails to stdout).
{%- if mailer %}
  provider: "smtp" # local default; set MAIL_PROVIDER=ses in production
{%- else %}
  provider: "" # log transport: credentials are written to the server log
{%- endif %}
  sender_address: "no-reply@{{ org_domain }}"
  sender_name: "{{ project_name }}"
  app_name: "{{ project_name }}"
  base_url: "http://localhost:8080" # used to build links (token method)
{%- if mailer %}
  smtp:
    # Local default points at Mailpit (docker-compose). No auth locally.
    host: "localhost"
    port: 1025
    username: ""
    password: ""
  ses:
    region: "us-east-1" # set via SES_REGION / falls back to AWS default chain
    access_key_id: ""
    secret_access_key: ""
{%- endif %}
{%- endif %}
{%- if caching == 'redis' %}

redis:
  # Overridden by REDIS_URL in docker-compose.
  url: "redis://localhost:6379"
{%- endif %}
{%- if eventing == 'kafka-redpanda' %}

kafka:
  # Overridden by KAFKA_BROKERS in docker-compose.
  brokers:
    - "localhost:9092"
{%- endif %}
{%- if payments == 'razorpay' %}

razorpay:
  key_id: ""     # set via RAZORPAY_KEY_ID
  key_secret: "" # set via RAZORPAY_KEY_SECRET
{%- endif %}
{%- if push_notifications == 'firebase' %}

firebase:
  credentials_file: "" # path to service-account JSON; set via FIREBASE_CREDENTIALS_FILE
{%- endif %}
{%- if object_storage == 's3' %}

storage:
  region: "us-east-1" # set via S3_REGION
  bucket: ""          # set via S3_BUCKET
  endpoint: ""        # optional; set via S3_ENDPOINT for S3-compatible services
{%- endif %}
