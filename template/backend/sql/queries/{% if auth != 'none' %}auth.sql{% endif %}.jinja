-- name: CreateUser :one
INSERT INTO users (email, password_hash, name, role)
VALUES ($1, $2, $3, $4)
RETURNING *;

-- name: GetUserByEmail :one
SELECT * FROM users WHERE email = $1;

-- name: GetUserByID :one
SELECT * FROM users WHERE id = $1;
{%- if auth == 'jwt-full' %}

-- name: VerifyUser :exec
UPDATE users SET verified = true, updated_at = now() WHERE id = $1;

-- name: UpdateUserPassword :exec
UPDATE users SET password_hash = $2, updated_at = now() WHERE id = $1;

-- name: CreateAuthToken :one
INSERT INTO auth_tokens (user_id, kind, token_hash, expires_at)
VALUES ($1, $2, $3, $4)
RETURNING *;
{%- if verification_method == 'otp' %}

-- name: GetLatestAuthToken :one
SELECT * FROM auth_tokens
WHERE user_id = $1 AND kind = $2 AND used_at IS NULL AND expires_at > now()
ORDER BY created_at DESC
LIMIT 1;
{%- else %}

-- name: GetAuthToken :one
SELECT * FROM auth_tokens
WHERE token_hash = $1 AND kind = $2 AND used_at IS NULL AND expires_at > now();
{%- endif %}

-- name: MarkAuthTokenUsed :exec
UPDATE auth_tokens SET used_at = now() WHERE id = $1;
{%- endif %}
