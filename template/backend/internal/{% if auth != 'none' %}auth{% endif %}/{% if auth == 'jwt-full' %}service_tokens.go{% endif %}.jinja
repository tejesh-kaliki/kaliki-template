package auth

import (
	"context"
	"crypto/rand"
	"crypto/sha256"
	"encoding/hex"
	"errors"
	"net/http"
	"time"

	"github.com/gin-gonic/gin"
	"github.com/google/uuid"

	gen "{{ go_module_path }}/gen/api/auth"
	"{{ go_module_path }}/internal/database"
)

const (
	kindVerify        = "verify"
	kindPasswordReset = "password_reset"
)

// VerifyEmail implements gen.ServerInterface (jwt-full). Consumes a verify
// token, marks the account verified, and returns a fresh session.
func (s *Service) VerifyEmail(c *gin.Context) {
	var body gen.VerifyEmailJSONRequestBody
	if err := c.ShouldBindJSON(&body); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	token, err := s.consumeToken(c.Request.Context(), body.Token, kindVerify)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid or expired token"})
		return
	}

	if err := s.store.q.VerifyUser(c.Request.Context(), token.UserID); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "could not verify user"})
		return
	}
	_ = s.store.q.MarkAuthTokenUsed(c.Request.Context(), token.ID)

	user, err := s.store.GetUserByID(c.Request.Context(), token.UserID)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "could not load user"})
		return
	}
	s.respondWithToken(c, http.StatusOK, user)
}

// RequestPasswordReset implements gen.ServerInterface (jwt-full). Always returns
// 200 so callers cannot probe which emails exist.
func (s *Service) RequestPasswordReset(c *gin.Context) {
	var body gen.RequestPasswordResetJSONRequestBody
	if err := c.ShouldBindJSON(&body); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	user, err := s.store.GetUserByEmail(c.Request.Context(), string(body.Email))
	if err != nil {
		c.JSON(http.StatusOK, gen.TokenResponse{})
		return
	}
	raw, err := s.issueToken(c.Request.Context(), user.ID, kindPasswordReset, time.Hour)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "could not issue reset"})
		return
	}
	// In production this token is emailed, not returned.
	c.JSON(http.StatusOK, gen.TokenResponse{Token: raw})
}

// ConfirmPasswordReset implements gen.ServerInterface (jwt-full).
func (s *Service) ConfirmPasswordReset(c *gin.Context) {
	var body gen.ConfirmPasswordResetJSONRequestBody
	if err := c.ShouldBindJSON(&body); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	token, err := s.consumeToken(c.Request.Context(), body.Token, kindPasswordReset)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid or expired token"})
		return
	}

	hash, err := HashPassword(body.Password)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "could not hash password"})
		return
	}

	if err := s.store.q.UpdateUserPassword(c.Request.Context(), database.UpdateUserPasswordParams{
		ID:           token.UserID,
		PasswordHash: hash,
	}); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": "could not update password"})
		return
	}
	_ = s.store.q.MarkAuthTokenUsed(c.Request.Context(), token.ID)
	c.Status(http.StatusOK)
}

func (s *Service) issueToken(ctx context.Context, userID uuid.UUID, kind string, ttl time.Duration) (string, error) {
	raw, hash := newToken()
	_, err := s.store.q.CreateAuthToken(ctx, database.CreateAuthTokenParams{
		UserID:    userID,
		Kind:      kind,
		TokenHash: hash,
		ExpiresAt: time.Now().Add(ttl),
	})
	return raw, err
}

func (s *Service) consumeToken(ctx context.Context, raw, kind string) (database.AuthToken, error) {
	token, err := s.store.q.GetAuthToken(ctx, database.GetAuthTokenParams{
		TokenHash: hashToken(raw),
		Kind:      kind,
	})
	if err != nil {
		return database.AuthToken{}, errors.New("token not found")
	}
	return token, nil
}

func newToken() (raw, hash string) {
	b := make([]byte, 32)
	_, _ = rand.Read(b)
	raw = hex.EncodeToString(b)
	return raw, hashToken(raw)
}

func hashToken(raw string) string {
	sum := sha256.Sum256([]byte(raw))
	return hex.EncodeToString(sum[:])
}
