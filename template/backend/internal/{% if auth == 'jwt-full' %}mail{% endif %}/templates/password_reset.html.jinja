<!DOCTYPE html>
<html>
<body style="font-family: sans-serif; color: #1a1a1a;">
  <h2>Reset your password</h2>
  <p>We received a request to reset your {{ '{{' }} .AppName {{ '}}' }} password.</p>
{%- if verification_method == 'otp' %}
  <p>Your password reset code is:</p>
  <p style="font-size: 28px; font-weight: bold; letter-spacing: 4px;">{{ '{{' }} .Code {{ '}}' }}</p>
  <p>This code expires in 15 minutes.</p>
{%- else %}
  <p>
    <a href="{{ '{{' }} .Link {{ '}}' }}"
       style="background:#1a1a1a;color:#fff;padding:12px 20px;border-radius:4px;text-decoration:none;">
      Reset password
    </a>
  </p>
  <p>Or paste this link into your browser:<br><a href="{{ '{{' }} .Link {{ '}}' }}">{{ '{{' }} .Link {{ '}}' }}</a></p>
  <p>This link expires in 1 hour.</p>
{%- endif %}
  <hr>
  <p style="color:#888;font-size:12px;">&copy; {{ '{{' }} .Year {{ '}}' }} {{ '{{' }} .AppName {{ '}}' }}. If you didn't request this, ignore this email.</p>
</body>
</html>
