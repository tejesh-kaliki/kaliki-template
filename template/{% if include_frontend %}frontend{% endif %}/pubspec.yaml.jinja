name: {{ project_slug | replace('-', '_') }}
description: {{ project_name }} Flutter app
publish_to: "none"
version: 0.1.0+1

environment:
  sdk: ">=3.5.0 <4.0.0"

dependencies:
  flutter:
    sdk: flutter
  flutter_riverpod: ^2.5.1
  riverpod_annotation: ^2.3.5
  go_router: ^14.0.0
  dio: ^5.4.0
{%- if shared_ui_source == 'vendored' %}
  shared_ui:
    path: packages/shared_ui
{%- else %}
  shared_ui:
    git:
      url: {{ shared_ui_git_url }}
      ref: {{ shared_ui_ref }}
{%- endif %}

dev_dependencies:
  flutter_test:
    sdk: flutter
  build_runner: ^2.4.0
  riverpod_generator: ^2.4.0

flutter:
  uses-material-design: true
